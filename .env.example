# ============================================================
# LumenX Auto-Reply Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# LumenX Platform
# Replace with your actual LumenX admin token. The demo deployment token
# is available in the project's api_description.txt (gitignored).
LUMENX_BASE_URL=https://lumenx-demo.up.railway.app
LUMENX_ADMIN_TOKEN=lmx_REPLACE_WITH_YOUR_TOKEN

# Agent Behaviour
CONFIDENCE_THRESHOLD=0.75        # Auto-send if score >= this value
POLL_INTERVAL_SECONDS=10         # How often to check the inbox
MIN_TRAIN_EXAMPLES=50            # Don't enable auto-send until this many labels
REVIEW_SAMPLE_RATE=0.10          # % of high-confidence drafts still sent to human review

# Storage
DB_PATH=./data/agent.db
WIKI_PATH=./wiki/pages

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change-me-in-production

# Logging
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
